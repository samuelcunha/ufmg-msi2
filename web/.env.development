# NEXT_PUBLIC_API_URL: used by the browser (client-side fetches).
# API_INTERNAL_URL: used only inside getServerSideProps (server-side fetches).
# Same value locally since there's no separate internal network; in Docker
# Compose/production these differ (API_INTERNAL_URL points at the private
# hostname/IP so SSR doesn't leave the internal network). See
# web/src/api/coverit.jsx.
NEXT_PUBLIC_API_URL=http://127.0.0.1:5001/
API_INTERNAL_URL=http://127.0.0.1:5001/

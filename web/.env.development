# NEXT_PUBLIC_API_URL: used by the browser (client-side fetches).
# There's also an optional API_INTERNAL_URL, used only inside
# getServerSideProps (server-side fetches) when the server can reach the API
# through a different/private host than the browser can — not needed here,
# falls back to NEXT_PUBLIC_API_URL. See web/src/api/coverit.jsx.
NEXT_PUBLIC_API_URL=http://127.0.0.1:5001/
